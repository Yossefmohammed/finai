# ─────────────────────────────────────────────
#  FinAI v3 — Environment Variables Template
#  Copy this file to .env and fill in your values
#  NEVER commit .env to Git
# ─────────────────────────────────────────────

# ── Security ──────────────────────────────────
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=your-very-secret-key-change-this
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Database ──────────────────────────────────
# SQLite (default for local dev):
DATABASE_URL=sqlite:///./finai.db

# PostgreSQL (recommended for production):
# DATABASE_URL=postgresql://user:password@localhost:5432/finai_db

# ── AI Providers (add only the ones you use) ──
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GROQ_API_KEY=gsk_...
GEMINI_API_KEY=...

# Ollama runs locally — no key needed, just set the base URL if non-default:
# OLLAMA_BASE_URL=http://localhost:11434

# ── App Settings ──────────────────────────────
APP_ENV=development        # development | production
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000